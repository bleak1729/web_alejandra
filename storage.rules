rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null
        && firestore.exists(/databases/(default)/documents/usuarios/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/usuarios/$(request.auth.uid)).data.rol == 'admin';
    }

    match /productos/{productoId}/{file=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /categorias/{file=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
